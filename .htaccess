# Apache .htaccess Configuration
# For Flutter Web Application on Apache Server
# Place this file in: /var/www/zwesta-trading/.htaccess

# Enable mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Skip rewrite for existing files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Redirect all requests to index.html
  RewriteRule ^.*$ index.html [L]
</IfModule>

# Enable gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/x-httpd-php
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  
  # Compress files with these extensions
  DeflateCompressionLevel 6
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Cache static assets for 30 days
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType font/ttf "access plus 30 days"
  ExpiresByType font/otf "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType application/wasm "access plus 30 days"
  
  # Cache JavaScript for 1 day (except main)
  ExpiresByType text/javascript "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  
  # Cache CSS for 1 day
  ExpiresByType text/css "access plus 1 day"
  
  # Cache manifest for 1 day
  ExpiresByType application/manifest+json "access plus 1 day"
  
  # No cache for HTML
  ExpiresByType text/html "access plus 0 seconds"
  
  # No cache for service worker
  <FilesMatch "flutter_service_worker\.js$">
    ExpiresActive Off
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  
  # Default
  ExpiresDefault "access plus 2 days"
</IfModule>

# Set MIME types
<IfModule mod_mime.c>
  AddType application/wasm .wasm
  AddType application/manifest+json .json
  AddEncoding gzip .js.gz
  AddEncoding gzip .css.gz
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  # Prevent clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  
  # Prevent MIME type sniffing
  Header always set X-Content-Type-Options "nosniff"
  
  # Enable XSS protection
  Header always set X-XSS-Protection "1; mode=block"
  
  # Set Referrer Policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Permissions Policy
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  
  # HSTS (HTTP Strict Transport Security)
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  
  # CORS Headers (adjust as needed)
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
  
  # Remove unnecessary headers
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# Deny access to sensitive files
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "^\.env">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Logging
<IfModule mod_log_config.c>
  CustomLog ${APACHE_LOG_DIR}/zwesta-trading-access.log combined
  ErrorLog ${APACHE_LOG_DIR}/zwesta-trading-error.log
</IfModule>

# Performance optimization
<IfModule mod_php.c>
  php_value upload_max_filesize 100M
  php_value post_max_size 100M
</IfModule>

# Disable directory listing
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# HTTP to HTTPS redirect (uncomment if behind proxy handling SSL)
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP:X-Forwarded-Proto} !https
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
