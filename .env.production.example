# Production Environment Configuration
# Copy to .env.production and customize for your deployment

# Environment
ZWESTA_ENV=production
FLASK_DEBUG=false
FLASK_ENV=production

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/zwesta/trading_backend.log
LOG_MAX_SIZE=100M
LOG_BACKUP_COUNT=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=9000
API_WORKERS=4
API_TIMEOUT=120
API_CORS_ORIGINS=*

# MT5 Configuration
MT5_ENABLED=true
MT5_ACCOUNT=104017418
MT5_PASSWORD=your_password_here
MT5_SERVER=MetaQuotes-Demo
MT5_PATH=/opt/mt5

# Database (if using)
DB_TYPE=sqlite
DB_PATH=/app/data/zwesta.db

# Redis Cache
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=86400

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Features
DEMO_MODE=false
ENABLE_WEBSOCKET=true
ENABLE_NOTIFICATIONS=true

# External Services
SENTRY_ENABLED=false
SENTRY_DSN=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_PATH=/app/backups
BACKUP_INTERVAL=86400
